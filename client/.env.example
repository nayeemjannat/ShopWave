# ============================================================
# ShopWave Client — Environment Variables
# Copy to .env for local development.
# For production (Vercel), set these in Vercel Dashboard:
#   Settings → Environment Variables
# ============================================================

# Local dev: http://localhost:5000
# Production: Your Render backend URL e.g. https://shopwave-api.onrender.com
VITE_API_URL=http://localhost:5000

# Must match a Store.slug in your MongoDB
VITE_STORE_SLUG=demo
